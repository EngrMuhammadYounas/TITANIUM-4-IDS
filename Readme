├── README.md
├── requirements.txt
├── LICENSE
├── layer1_preprocess.py          # Data ingestion and feature extraction
├── layer2_gatekeeper.py          # Binary gatekeeper training
├── layer3_forensics.py           # Multi-class attack classifier
├── layer4_sentinel.py            # Zero-day sentinel (OC-SVM)
├── inference.py                  # Live traffic inference pipeline
├── config.yaml                   # Configuration file
├── docs/
│   └── CYBERGUARD_v6_final.docx  # Full thesis
├── notebooks/
│   └── fyp-intrusion-detection-system.ipynb
