│   ├── l2_gatekeeper.pkl
│   ├── l3_forensics.pkl
│   └── l4_sentinel.pkl
├── layer1_output/                # Preprocessed Parquet files
│   ├── l2_train.parquet
│   ├── l2_val.parquet
│   ├── l2_test_known.parquet
│   ├── l3_train_attack.parquet
│   ├── l3_val_attack.parquet
│   ├── l4_train_normal.parquet
│   ├── l4_val_normal.parquet
│   ├── l4_test_zeroday.parquet
│   ├── set_a_features.json
│   ├── set_b_features.json
│   ├── scaler_a.pkl
│   └── scaler_b.pkl
├── results/
│   ├── inference_results.csv
│   ├── l2_feature_importance.png
│   ├── l2_shap_summary.png
│   └── l3_feature_importance.png
└── tests/
    ├── test_layer2.py
    ├── test_layer3.py
    └── test_layer4.py
```

